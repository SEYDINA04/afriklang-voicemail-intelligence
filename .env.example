# ── Twilio (WhatsApp Sandbox) ──────────────────────────────
# Console: https://console.twilio.com  →  Messaging → Try it out → WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Sandbox sender (default Twilio WhatsApp sandbox number)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Set to false to skip Twilio signature validation in local dev
TWILIO_VALIDATE_SIGNATURE=true

# ── Afriklang ASR API ──────────────────────────────────────
AFRIKLANG_BASE_URL=https://asr.afriklang.com
AFRIKLANG_TIMEOUT_SECONDS=60
# Default language when a user has no stored preference (wo | twi)
DEFAULT_LANGUAGE=twi

# ── Application ────────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./data/afriklang.db

# ── Audio conversion ───────────────────────────────────────
# If true and ffmpeg is available, convert incoming OGG/Opus to WAV 16k mono.
# If false (or ffmpeg missing), the original audio bytes are forwarded to the ASR API.
AUDIO_CONVERT_TO_WAV=false
